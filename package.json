{
  "name": "claudex",
  "version": "0.0.1",
  "private": true,
  "description": "Remote Control for Claude Code — a browser front-end for the claude CLI on your own machine.",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "pnpm -r --parallel run dev",
    "build": "pnpm --filter @claudex/web run build",
    "start": "NODE_ENV=production pnpm --filter @claudex/server exec tsx src/index.ts",
    "serve": "pnpm build && pnpm start",
    "typecheck": "pnpm -r run typecheck",
    "lint": "pnpm -r run lint",
    "test": "pnpm --filter @claudex/server run test",
    "server": "pnpm --filter @claudex/server",
    "web": "pnpm --filter @claudex/web",
    "shared": "pnpm --filter @claudex/shared",
    "init": "pnpm --filter @claudex/server exec tsx src/bin/init.ts"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  }
}
